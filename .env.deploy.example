# ===== Deployment =====
# For a domain with automatic HTTPS, use: CADDY_DOMAIN=logos.example.com
# For IP-only or local smoke tests, use: CADDY_DOMAIN=:80
CADDY_DOMAIN=:80
BASIC_AUTH_USER=admin
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'change-me'
# Wrap bcrypt hashes in single quotes so dollar signs remain literal.
# Replace before deployment. Example format: BASIC_AUTH_HASH='$2a$14$...'
BASIC_AUTH_HASH=REPLACE_WITH_CADDY_HASH
POSTGRES_PASSWORD=postgres
REDIS_PASSWORD=change-redis-password

# ===== Application security =====
APP_ENV=production
AUTH_ENABLED=true
REPORT_QUALITY_MIN_SCORE=0.75
REPORT_QUALITY_AUTO_PUBLISH=false

# ===== LLM 配置 =====
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ===== Embedding 配置 =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# ===== Rerank 重排序 =====
RERANK_ENABLED=false
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=
RERANK_TOP_K_MULTIPLIER=3

# ===== 报告质量 Judge 配置 =====
JUDGE_PROVIDER=openai_compatible
JUDGE_API_KEY=
JUDGE_BASE_URL=
JUDGE_MODEL=
JUDGE_TEMPERATURE=0
JUDGE_MAX_TOKENS=2048

# ===== 结构化事实抽取配置 =====
STRUCTURED_EXTRACTION_PROVIDER=openai_compatible
STRUCTURED_EXTRACTION_API_KEY=
STRUCTURED_EXTRACTION_BASE_URL=
STRUCTURED_EXTRACTION_MODEL=
STRUCTURED_EXTRACTION_TEMPERATURE=0
STRUCTURED_EXTRACTION_MAX_TOKENS=2048

# ===== Storage / Runtime inside Docker Compose =====
# If POSTGRES_PASSWORD changes, update the password portion of PG_DSN too.
PG_DSN=postgresql://postgres:postgres@postgres:5432/logos
EMBEDDING_VECTOR_SIZE=1536
CELERY_BROKER_URL=redis://:change-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-redis-password@redis:6379/0
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_DOCUMENTS_COLLECTION=insightforge_documents_v1
QDRANT_DISTANCE=Cosine

# ===== Other =====
LOG_LEVEL=INFO
ARTICLE_RETENTION_DAYS=90
NEWSAPI_KEY=
NEWSAPI_API_KEY=
TAVILY_API_KEY=
