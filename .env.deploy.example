# ===== Deployment =====
# For a domain with automatic HTTPS, use: CADDY_DOMAIN=logos.example.com
# For IP-only or local smoke tests, use: CADDY_DOMAIN=:80
CADDY_DOMAIN=:80
BASIC_AUTH_USER=admin
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'change-me'
# Wrap bcrypt hashes in single quotes so dollar signs remain literal.
# Example: BASIC_AUTH_HASH='$2a$14$...'
BASIC_AUTH_HASH=
POSTGRES_PASSWORD=postgres

# ===== LLM 配置 =====
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ===== Embedding 配置 =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# ===== Rerank 重排序 =====
RERANK_ENABLED=false
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=
RERANK_TOP_K_MULTIPLIER=3

# ===== Storage / Runtime inside Docker Compose =====
# If POSTGRES_PASSWORD changes, update the password portion of PG_DSN too.
PG_DSN=postgresql://postgres:postgres@postgres:5432/logos
EMBEDDING_VECTOR_SIZE=1536
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===== Other =====
LOG_LEVEL=INFO
ARTICLE_RETENTION_DAYS=90
NEWSAPI_KEY=
TAVILY_API_KEY=

# ===== AI 摘要配置 =====
SUMMARY_USE_SAME_LLM=true
SUMMARY_LLM_PROVIDER=
SUMMARY_LLM_API_KEY=
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_MODEL=
SUMMARY_BATCH_SIZE=5
