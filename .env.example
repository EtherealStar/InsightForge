# ===== LLM 配置 =====
# 默认使用 OpenAI 格式自定义 API
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# GPT 官方（可选，设置 LLM_PROVIDER=openai 时使用）
OPENAI_API_KEY=

# Gemini 官方（可选，设置 LLM_PROVIDER=gemini 时使用）
GOOGLE_API_KEY=

# Claude 官方（可选，设置 LLM_PROVIDER=anthropic 时使用）
ANTHROPIC_API_KEY=

# ===== 结构化抽取配置 =====
# facts/events 抽取使用；可与主 LLM 使用同一服务，但需要单独填写
STRUCTURED_EXTRACTION_PROVIDER=openai_compatible
STRUCTURED_EXTRACTION_API_KEY=
STRUCTURED_EXTRACTION_BASE_URL=
STRUCTURED_EXTRACTION_MODEL=
STRUCTURED_EXTRACTION_TEMPERATURE=0.0
STRUCTURED_EXTRACTION_MAX_TOKENS=2048

# ===== 报告质量 Judge 配置 =====
# 报告质量审查使用；可与主 LLM 使用同一服务，但需要单独填写
JUDGE_PROVIDER=openai_compatible
JUDGE_API_KEY=
JUDGE_BASE_URL=
JUDGE_MODEL=
JUDGE_TEMPERATURE=0.0
JUDGE_MAX_TOKENS=2048

# ===== Embedding 配置 =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# ===== Rerank 重排序 =====
RERANK_ENABLED=false
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=
RERANK_TOP_K_MULTIPLIER=3

# ===== 存储 =====
# Docker Compose 默认值，无需修改即可连接本地容器
PG_DSN=postgresql://postgres:postgres@localhost:5432/logos
EMBEDDING_VECTOR_SIZE=1536

# ===== 其他 =====
APP_ENV=development
AUTH_ENABLED=false
APP_API_KEYS=
LOG_LEVEL=INFO
ARTICLE_RETENTION_DAYS=90

# ===== NewsAPI =====
NEWSAPI_KEY=

# ===== 搜索引擎 =====
TAVILY_API_KEY=

# ===== AI 摘要配置 =====
SUMMARY_USE_SAME_LLM=true
SUMMARY_LLM_PROVIDER=
SUMMARY_LLM_API_KEY=
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_MODEL=
SUMMARY_BATCH_SIZE=5

# ===== Celery / Redis =====
# Docker Compose 默认值，无需修改即可连接本地容器
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
