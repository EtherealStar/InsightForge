# ===== LLM 配置 =====
# 默认使用 OpenAI 格式自定义 API
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# GPT 官方（可选，设置 LLM_PROVIDER=openai 时使用）
OPENAI_API_KEY=

# Gemini 官方（可选，设置 LLM_PROVIDER=gemini 时使用）
GOOGLE_API_KEY=

# Claude 官方（可选，设置 LLM_PROVIDER=anthropic 时使用）
ANTHROPIC_API_KEY=

# ===== Embedding 配置 =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# ===== 其他 =====
LOG_LEVEL=INFO
ARTICLE_RETENTION_DAYS=90
